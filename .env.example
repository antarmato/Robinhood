# Anthropic API (required — agents run on Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: protect the proposals API so only your Cowork artifact can call it
# Set a random string here and enter the same value in the Cowork artifact settings
API_KEY=

# Trading config
MAX_LOSS_PER_TRADE=200          # Max dollars to risk per trade (option premium)
WATCHLIST=SPY,QQQ,NVDA,AAPL,MSFT,TSLA,AMZN,META,GOOGL
SCAN_INTERVAL_MINUTES=30        # How often to scan for new opportunities
MONITOR_INTERVAL_MINUTES=15     # How often to check open positions for exit signals
MIN_IV_RANK=20                  # Only trade when IV rank >= this
MAX_DTE=21                      # Max days to expiration to consider
MIN_DTE=5                       # Min days to expiration to consider

# Deployment
PORT=8000
